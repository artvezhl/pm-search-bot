# Polymarket (required for trading)
POLYMARKET_PK=****
POLY_API_KEY=****
POLY_API_SECRET=****
POLY_API_PASSPHRASE=****

# Wallet address from polymarket.com/settings (proxy/safe where funds are held). If empty, auto-derived.
POLYMARKET_PROXY_ADDRESS=0x545b1915c3a984fa7b89ca7282d2414568be7b8d
# Wallet type: "safe" (default, Gnosis Safe - most users) or "proxy" (Magic/email login)
POLYMARKET_WALLET_TYPE=safe

# Polygon RPC URL
POLYGON_RPC_URL=https://polygon-bor.publicnode.com

# Set to 1 to log submit payload for debugging
RELAYER_DEBUG=1

# Anthropic Claude API key (требуется для стратегии claude_advisor).
# Получить: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-****

# Relayer (for gasless redeem)
RELAYER_API_KEY=***
RELAYER_API_KEY_ADDRESS=0x2794b24024C0a57d399Fd979384a07a4A3b37E8c

# Telegram
TELEGRAM_BOT_TOKEN=****
# Comma-separated list of allowed Telegram user IDs (empty = allow all)
TELEGRAM_ALLOWED_IDS=86157241,199140321

TRADER_NOTIFY_CHAT_ID=-1003741255240