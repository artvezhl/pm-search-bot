      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT date_trunc('day', closed_at) AS time, SUM(pnl_usd)::float AS pnl_usd FROM bot_positions WHERE status='closed' AND closed_at > NOW() - INTERVAL '30 days' GROUP BY 1 ORDER BY 1",
