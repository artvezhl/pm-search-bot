# ===== Mode =====
# true = paper trading (SIMULATION), false = live orders via py-clob-client
SIMULATION_MODE=true
STARTING_BALANCE=10000

# ===== Polymarket (required in live mode) =====
POLYMARKET_PK=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
# Wallet address from polymarket.com/settings (Safe proxy). Empty = auto-derive
POLYMARKET_PROXY_ADDRESS=
# safe (default, Gnosis Safe) or proxy (Magic/email)
POLYMARKET_WALLET_TYPE=safe

POLYGON_RPC_URL=https://polygon-bor.publicnode.com

# ===== Polymarket endpoints =====
CLOB_HOST=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_HOST=https://gamma-api.polymarket.com
DATA_API_HOST=https://data-api.polymarket.com

# Alchemy
ALCHEMY_POLYGON_URL=https://polygon-mainnet.g.alchemy.com/v2/******

# ===== Infra =====
POSTGRES_DSN=postgresql+asyncpg://polybot:polybot@postgres:5432/polybot
POSTGRES_DSN_SYNC=postgresql+psycopg2://polybot:polybot@postgres:5432/polybot
REDIS_URL=redis://redis:6379/0

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
# comma-separated list of allowed user IDs (empty = allow all)
TELEGRAM_ALLOWED_IDS=
# where daily reports + notifications are posted
TRADER_NOTIFY_CHAT_ID=

# ===== API server =====
API_HOST=0.0.0.0
API_PORT=8000

# ===== Player tracker thresholds =====
MIN_WINRATE=0.60
MIN_TOTAL_VOLUME_USD=5000
MIN_TRADES_COUNT=10
PLAYER_STATS_LOOKBACK_DAYS=90

# ===== Cluster detector =====
DBSCAN_EPS=0.05
DBSCAN_MIN_SAMPLES=3
TIME_WINDOW_MINUTES=60

# ===== Signal engine =====
MIN_CLUSTER_SIZE=3
MIN_POSITION_USD=500
MAX_ENTRY_LAG_MIN=15
MIN_CLUSTER_SCORE=0.65
MIN_MARKET_LIQUIDITY=10000

# ===== Risk manager =====
MAX_POSITION_PCT=0.05
MAX_OPEN_POSITIONS=10
MAX_DAILY_LOSS_PCT=0.10
POSITION_STOP_LOSS_PCT=0.50
MAX_SAME_MARKET_EXPOSURE=0.10

# ===== Exit watcher =====
EXIT_ON_FIRST_LEADER=true
MAX_HOLD_DAYS=7
EXIT_LAG_SECONDS=30

# ===== Scheduling =====
INGESTION_POLL_INTERVAL_SEC=30
CLUSTER_DETECT_INTERVAL_SEC=300
PLAYER_TRACKER_INTERVAL_SEC=3600
EXIT_CHECK_INTERVAL_SEC=60
DAILY_REPORT_HOUR_LOCAL=9
MARKET_SYNC_CRON_HOURS=2
WALLET_ANALYZER_CRON_HOURS=6
NETWORK_DETECTOR_CRON_HOURS=12
CLEANUP_CRON_WEEKDAY=0
CLEANUP_CRON_HOUR_UTC=3

# ===== PM analytics module =====
PM_HISTORY_DAYS=180
PM_MIN_RESOLVED_MARKETS=15
PM_SMART_WALLET_THRESHOLD=0.55
PM_MIN_WALLET_WIN_RATE=0.55
PM_MIN_WALLET_VOLUME_USDC=500
PM_NETWORK_WINDOW_MINUTES=5
PM_NETWORK_LOOKBACK_DAYS=30
PM_MAX_PARALLEL_MARKET_POLLS=5
PM_COPY_MAX_PRICE=0.75
PM_COPY_MIN_HOURS_TO_CLOSE=2
BOT_CAPITAL_USDC=1000
MAX_SINGLE_POSITION_USDC=50

# ===== On-chain backfill =====
ONCHAIN_BACKFILL_ENABLED=true
ONCHAIN_BACKFILL_DAYS=30
ONCHAIN_BACKFILL_CHUNK_SIZE=2000

# ===== Optional (v2) =====
USE_THE_GRAPH=false
THEGRAPH_API_KEY=

# ===== Logging =====
LOG_LEVEL=INFO
